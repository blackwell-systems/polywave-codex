#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/build-wave-agent-prompt \
  --agent-id <id> \
  --worktree-path <path> \
  --branch <name> \
  --brief-path <path> \
  --repo-dir <repo> \
  [--journal-context-file <path>]

Builds the fully injected Polywave Wave Agent prompt for Codex delegation.
USAGE
}

agent_id=""
worktree_path=""
branch_name=""
brief_path=""
journal_context_file=""
repo_dir=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent-id)
      agent_id="$2"
      shift 2
      ;;
    --worktree-path)
      worktree_path="$2"
      shift 2
      ;;
    --branch)
      branch_name="$2"
      shift 2
      ;;
    --brief-path)
      brief_path="$2"
      shift 2
      ;;
    --journal-context-file)
      journal_context_file="$2"
      shift 2
      ;;
    --repo-dir)
      repo_dir="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$agent_id" || -z "$worktree_path" || -z "$branch_name" || -z "$brief_path" || -z "$repo_dir" ]]; then
  usage >&2
  exit 2
fi

require_command() {
  local name="$1"
  command -v "$name" >/dev/null 2>&1 || {
    printf 'Missing required command: %s\n' "$name" >&2
    exit 1
  }
}

require_command python3
worktree_path="$(python3 - "$worktree_path" <<'PYABS'
import os
import sys
print(os.path.abspath(sys.argv[1]))
PYABS
)"
brief_path="$(python3 - "$brief_path" <<'PYABS2'
import os
import sys
print(os.path.abspath(sys.argv[1]))
PYABS2
)"
repo_dir="$(python3 - "$repo_dir" <<'PYABS3'
import os
import sys
print(os.path.abspath(sys.argv[1]))
PYABS3
)"
if [[ -n "$journal_context_file" ]]; then
  journal_context_file="$(python3 - "$journal_context_file" <<'PYABS4'
import os
import sys
print(os.path.abspath(sys.argv[1]))
PYABS4
)"
fi

script_dir="$(cd "$(dirname "$0")" && pwd)"
skill_dir="${POLYWAVE_SKILL_DIR:-$(cd "$script_dir/.." && pwd)}"
agent_path="$HOME/.codex/agents/polywave-wave-agent.toml"
if [[ ! -f "$agent_path" ]]; then
  agent_path="$skill_dir/../../agents/polywave-wave-agent.toml"
fi

prompt="$(python3 - "$agent_id" "$worktree_path" "$branch_name" "$brief_path" "$journal_context_file" "$repo_dir" "$agent_path" <<'PYBUILD'
from pathlib import Path
import sys
import tomllib
agent_id, worktree_path, branch_name, brief_path, journal_context_file, repo_dir, agent_path = sys.argv[1:8]
with Path(agent_path).open('rb') as f:
    data = tomllib.load(f)
instructions = data['developer_instructions'].rstrip()
brief_text = Path(brief_path).read_text()
journal_text = ''
if journal_context_file:
    jpath = Path(journal_context_file)
    if jpath.exists():
        journal_text = '\n\n## Session Context (Recovered from Tool Journal)\n\n' + jpath.read_text().rstrip() + '\n'
print(f"""Use the following Polywave Wave Agent instructions as your role. Follow them exactly, with the Codex-specific execution notes below.

{instructions}

## Codex Execution Notes

- You are running under Codex, launched directly in your prepared worktree.
- Your working directory is: {worktree_path}
- Your branch is: {branch_name}
- Your agent id is: {agent_id}
- Repository root for Polywave tool commands is: {repo_dir}
- Read and follow the prepared brief below as the instance-layer assignment.
- When repository context must be explicit, use the global flag form: `polywave-tools --repo-dir {repo_dir} set-completion ...`.
- Do not stop at analysis if implementation is feasible. Complete the assigned work in this worktree.
- Do not modify files outside the prepared worktree except through protocol-authorized commands like `polywave-tools set-completion` that update the IMPL manifest.
{journal_text}
## Prepared Brief

{brief_text}
""")
PYBUILD
)"

inject_script="$skill_dir/scripts/inject-agent-context"
if [[ -x "$inject_script" ]]; then
  inject_content="$($inject_script --type wave-agent --prompt "$prompt" 2>/dev/null)" || true
  if [[ -n "$inject_content" ]]; then
    printf '%s\n\n%s\n' "$inject_content" "$prompt"
    exit 0
  fi
fi

printf '%s\n' "$prompt"
